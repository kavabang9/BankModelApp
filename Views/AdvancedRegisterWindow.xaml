<Window x:Class="BankModelApp.Views.AdvancedRegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BankModelApp.Views"
        mc:Ignorable="d"
        Title="Регистрация" 
        Height="450" 
        Width="400">
    <Grid>
        <Label Content="Продолжение регистрации" 
               HorizontalAlignment="Center" 
               Margin="0,10,0,0" 
               VerticalAlignment="Top"
               FontSize="29"/>
        <TextBox HorizontalAlignment="Center" 
                 Margin="0,109,0,0" 
                 TextWrapping="Wrap" 
                 Text="" 
                 VerticalAlignment="Top" 
                 Width="200"
                 Height="35"/>
        <TextBox HorizontalAlignment="Center" 
                 TextWrapping="Wrap" 
                 Text="" 
                 VerticalAlignment="Top" 
                 Width="200" 
                 Height="35"
                 FontSize="20" 
                 Margin="0,174,0,0"/>
        <TextBox HorizontalAlignment="Center" 
            Margin="0,244,0,0" 
            TextWrapping="Wrap" 
            Text="" 
            VerticalAlignment="Top" 
            Width="200" 
            Height="35"
            FontSize="20"/>
        <Button Content="Продолжить" 
            HorizontalAlignment="Center" 
            Margin="0,329,0,0" 
            VerticalAlignment="Top" 
            Height="55" 
            Width="130"
            FontSize="15"/>
        <CheckBox Content="Вы юридическое лицо?" 
                  HorizontalAlignment="Center" 
                  Margin="0,299,0,0" 
                  VerticalAlignment="Top">
            <CheckBox.ToolTip>
                <ToolTip>
                    <StackPanel>
                        <TextBlock>
                            Если вы оставите галочку на этом пункте,
                            то необходимо будет пройти дополнительную регистрацию
                            для юридических лиц!
                        </TextBlock>
                        <TextBlock>
                            Если вы оставите галочку на этом пункте, 
                            то выбудете получать специальные предложения 
                            по банковским операциям для юридических лиц!
                        </TextBlock>
                    </StackPanel>
                </ToolTip>
            </CheckBox.ToolTip>
        </CheckBox>
    </Grid>
</Window>
