<Window x:Class="BankingActivitiesApp.View.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BankingActivitiesApp.View"
        mc:Ignorable="d"
        Title="Окно регистрации" 
        Height="450" 
        Width="400">
    <Grid>
        <Label Content="Регистрация" 
               HorizontalAlignment="Center" 
               Margin="0,29,0,0" 
               VerticalAlignment="Top" 
               Width="250"
               FontSize="40"/>
        <TextBox HorizontalAlignment="Center" 
                 Margin="0,159,0,0" 
                 TextWrapping="Wrap" 
                 Text="" 
                 VerticalAlignment="Top" 
                 Width="200" 
                 Height="35"
                 FontSize="20"/>
        <TextBox HorizontalAlignment="Center" 
            Margin="0,234,0,0" 
            TextWrapping="Wrap" 
            Text="" 
            VerticalAlignment="Top" 
            Width="200" 
            Height="35"
            FontSize="20"/>
        <Label Content="Введите телефон" 
            HorizontalAlignment="Center" 
            Margin="0,124,0,0" 
            VerticalAlignment="Top" 
            Width="200"
            FontSize="15"/>
        <Label Content="Введите пароль" 
            HorizontalAlignment="Center" 
            Margin="0,199,0,0" 
            VerticalAlignment="Top" 
            Width="200"
            FontSize="15"/>
        <Button Content="Продолжить" 
                HorizontalAlignment="Center" 
                Margin="0,289,0,0" 
                VerticalAlignment="Top" 
                Height="55" 
                Width="130"/>
        <Label
            HorizontalAlignment="Center" 
            Margin="0,359,0,0" 
            VerticalAlignment="Top" 
            Width="400"
            Height="25"
            FontSize="15"
            Padding="0"
            Cursor="Hand">
            <TextBlock TextAlignment="Center" 
                       Width="400">
                <Hyperlink NavigateUri="https://example.com" 
                       RequestNavigate="Hyperlink_RequestNavigate"
                       Command="{Binding OpenLinkCommand}">
                           Аккаунт уже существует?
                </Hyperlink>
            </TextBlock>
        </Label>
    </Grid>
</Window>
